generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id              String   @id @default(uuid())
  name            String
  pan             String
  businessType    String
  monthlyRevenue  Float
  loanAmount      Float
  tenure          Int

  decision        String
  creditScore     Int
  reasons         Json

  createdAt       DateTime @default(now())
}
